  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Get Token (Admin / Warehouse)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"client_id\": \"demo_user\",\n    \"client_secret\": \"secret123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/auth/token?lang=en",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["auth", "token"],
              "query": [{"key": "lang", "value": "en"}]
            }
          }
        },
        {
          "name": "Get Token (France Demo Account)",
          "request": {
            "method": "POST",
            "header": [
